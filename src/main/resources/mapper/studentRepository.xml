<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="raisetech.StudentManagement.repositry.StudentRepository">

  <!-- 受講生 -->
  <resultMap id="studentMap" type="raisetech.StudentManagement.data.Student">
    <id column="id" property="id"/>
    <result column="full_name" property="fullName"/>
    <result column="furigana" property="furigana"/>
    <result column="nickname" property="nickname"/>
    <result column="email" property="email"/>
    <result column="region" property="region"/>
    <result column="age" property="age"/>
    <result column="gender" property="gender"/>
    <result column="remark" property="remark"/>
    <result column="is_deleted" property="isDeleted"/>
  </resultMap>

  <!-- 受講生コース -->
  <resultMap id="studentCourseMap" type="raisetech.StudentManagement.data.StudentCourse">
    <id column="id" property="id"/>
    <result column="student_id" property="studentId"/>
    <result column="course_name" property="courseName"/>
    <result column="start_date" property="startDate"/>
    <result column="end_date" property="endDate"/>
    <result column="status" property="status"/>
  </resultMap>


  <!-- ========================= -->
  <!-- 受講生 -->
  <!-- ========================= -->

  <!-- 全件検索 -->
  <select id="search" resultMap="studentMap">
    SELECT * FROM students
  </select>

  <!-- ID検索 -->
  <select id="searchStudent" resultMap="studentMap">
    SELECT * FROM students
    WHERE id = #{id}
  </select>

  <!-- 登録 -->
  <insert id="registerStudent"
    parameterType="raisetech.StudentManagement.data.Student"
    useGeneratedKeys="true"
    keyProperty="id">

    INSERT INTO students
    (full_name, furigana, nickname, email, region, age, gender, remark, is_deleted)
    VALUES
    (#{fullName}, #{furigana}, #{nickname}, #{email}, #{region}, #{age},
    #{gender}, #{remark}, COALESCE(#{isDeleted}, false))
  </insert>

  <!-- 更新 -->
  <update id="updateStudent"
    parameterType="raisetech.StudentManagement.data.Student">

    UPDATE students
    SET full_name = #{fullName},
    furigana = #{furigana},
    nickname = #{nickname},
    email = #{email},
    region = #{region},
    age = #{age},
    gender = #{gender},
    remark = #{remark},
    is_deleted = #{isDeleted}
    WHERE id = #{id}
  </update>


  <!-- ========================= -->
  <!-- 受講生コース -->
  <!-- ========================= -->

  <!-- 全件検索 -->
  <select id="searchStudentCourseList" resultMap="studentCourseMap">
    SELECT * FROM students_courses
  </select>

  <!-- 受講生ID検索 -->
  <select id="searchStudentCourse" resultMap="studentCourseMap">
    SELECT * FROM students_courses
    WHERE student_id = #{studentId}
  </select>

  <!-- 登録 -->
  <insert id="registerStudentCourse"
    parameterType="raisetech.StudentManagement.data.StudentCourse"
    useGeneratedKeys="true"
    keyProperty="id">

    INSERT INTO students_courses
    (student_id, course_name, start_date, end_date,status)
    VALUES
    (#{studentId}, #{courseName}, #{startDate}, #{endDate}, #{status})
  </insert>

  <!-- 更新 -->
  <update id="updateStudentCourse"
    parameterType="raisetech.StudentManagement.data.StudentCourse">

    UPDATE students_courses
    SET course_name = #{courseName},
    start_date = #{startDate},
    end_date = #{endDate},
    status = #{status}
    WHERE id = #{id}
  </update>

</mapper>